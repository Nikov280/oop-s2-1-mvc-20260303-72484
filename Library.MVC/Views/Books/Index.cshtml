@model IEnumerable<Library.Domain.Book>

@{
    ViewData["Title"] = "Books";
}

<h1>Book List</h1>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-lg"></i> Add New Book
            </a>
        }
    </div>

    <form asp-action="Index" method="get" class="row g-3 mb-4 p-3 bg-light border rounded">

        <div class="col-md-4">
            <label class="form-label fw-bold">Search</label>
            <input type="text" name="searchString" value="@ViewContext.HttpContext.Request.Query["searchString"]"
                   class="form-control" placeholder="Title or Author..." />
        </div>

        <div class="col-md-3">
            <label class="form-label fw-bold">Category</label>
            <select name="category" class="form-select">
                <option value="">All Categories</option>
                <option value="Fiction">Fiction</option>
                <option value="Science">Science</option>
                <option value="History">History</option>
                <option value="Biography">Biography</option>
            </select>
        </div>

        <div class="col-md-3">
            <label class="form-label fw-bold">Status</label>
            <select name="availability" class="form-select">
                <option value="All">All Books</option>
                <option value="Available">Available Only</option>
                <option value="OnLoan">Currently on Loan</option>
            </select>
        </div>

        <div class="col-md-2 d-flex align-items-end gap-2">
            <button type="submit" class="btn btn-dark w-100">Filter</button>
            <a asp-action="Index" class="btn btn-outline-secondary w-100">Reset</a>
        </div>
    </form>

    <table class="table table-striped table-hover mt-3 table-bordered">
        <thead class="table-dark text-center">
            <tr>
                <th>@Html.DisplayNameFor(model => model.Title)</th>
                <th>@Html.DisplayNameFor(model => model.Author)</th>
                <th>@Html.DisplayNameFor(model => model.Category)</th>
                <th>@Html.DisplayNameFor(model => model.Isbn)</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody class="text-center align-middle">
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Title</td>
                    <td>@item.Author</td>
                    <td>@item.Category</td>
                    <td>@item.Isbn</td>

                    <td>
                        @if (item.IsAvailable)
                        {
                            <span class="badge bg-success rounded-pill px-3">Available</span>
                        }
                        else
                        {
                            <span class="badge bg-danger rounded-pill px-3">On Loan</span>
                        }
                    </td>

                    <td>
                        <div class="btn-group btn-group-sm">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info">Details</a>
                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning">Edit</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger">Delete</a>
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
