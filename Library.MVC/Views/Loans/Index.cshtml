@model IEnumerable<Library.Domain.Loan>

@{
    ViewData["Title"] = "Loans Management";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">@ViewData["Title"]</h2>
        <a asp-action="Create" class="btn btn-success">
            <i class="bi bi-plus-lg"></i> New Loan Request
        </a>
    </div>

    <hr />

    @if (Model != null && Model.Any())
    {
        
        <h4 class="mb-3 text-secondary">
            @(User.IsInRole("Admin") ? "All Registered Loans" : "My Active Loans")
        </h4>

        <table class="table table-hover table-bordered mt-3">
            <thead class="table-dark text-center">
                <tr>
                    <th>Book Title</th>
                    <th>Member Name</th>
                    <th>@Html.DisplayNameFor(model => model.LoanDate)</th>
                    <th>@Html.DisplayNameFor(model => model.DueDate)</th>
                    <th>Status</th>
                    @if (User.IsInRole("Admin"))
                    {
                        <th>Actions</th>
                    }
                </tr>
            </thead>
            <tbody class="text-center align-middle">
                @foreach (var item in Model)
                {
                    
                    var isOverdue = item.ReturnedDate == null && item.DueDate < DateTime.Now;

                    <tr class="@(isOverdue ? "table-danger" : "")">
                        <td class="fw-bold">@item.Book?.Title</td> 
                        <td>@item.Member?.FullName</td>    
                        <td>@item.LoanDate.ToShortDateString()</td>
                        <td>@item.DueDate.ToShortDateString()</td>
                        <td>
                            @if (item.ReturnedDate.HasValue)
                            {
                                <span class="badge bg-secondary rounded-pill px-3">Returned</span>
                            }
                            else if (item.DueDate < DateTime.Now)
                            {
                                <span class="badge bg-danger rounded-pill px-3">Overdue</span>
                            }
                            else
                            {
                                <span class="badge bg-primary rounded-pill px-3">Active</span>
                            }
                        </td>

                        @if (User.IsInRole("Admin"))
                        {
                            <td>
                                <div class="btn-group btn-group-sm">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info text-white">Details</a>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning">Edit</a>                                    
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger">Delete</a>
                                </div>
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        
        <div class="text-center p-5 border rounded bg-light mt-4">
            <i class="bi bi-info-circle text-info" style="font-size: 2rem;"></i>
            <h4 class="mt-3">No loans found</h4>
            <p class="text-muted">You don't have any active loans at the moment.</p>
            <a asp-controller="Books" asp-action="Index" class="btn btn-outline-primary">Browse Library</a>
        </div>
    }
</div>