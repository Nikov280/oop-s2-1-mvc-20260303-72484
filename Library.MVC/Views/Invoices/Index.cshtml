@model IEnumerable<Library.Domain.Invoice>

<h2>Invoices List</h2>
<p>
    <a asp-action="Create" class="btn btn-primary">Create New Invoice</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>Date</th>
            <th>Customer</th>
            <th>No. lines</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Date.ToShortDateString()</td>
                <td>@item.CustomerName</td>
                <td>@item.InvoiceLines.Count</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id">Details</a>
                </td>
            </tr>
        }
    </tbody>
</table>